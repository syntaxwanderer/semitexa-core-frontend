<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ statusCode|default(500) }} {{ reasonPhrase|default('Error') }}</title>
    {{ semantic_head() }}
    {{ asset_head() }}
    <style>
      :root{
        --error-bg:#f4efe7;
        --error-ink:#14202b;
        --error-muted:#53606b;
        --error-card:#fffaf2;
        --error-line:rgba(20,32,43,.14);
        --error-accent:#d96d3f;
        --error-accent-soft:rgba(217,109,63,.12);
      }
      *{box-sizing:border-box}
      body{
        margin:0;
        min-height:100vh;
        background:
          radial-gradient(circle at top left, rgba(217,109,63,.18), transparent 28rem),
          radial-gradient(circle at bottom right, rgba(20,32,43,.12), transparent 30rem),
          linear-gradient(180deg, #f8f3eb 0%, var(--error-bg) 100%);
        color:var(--error-ink);
        font-family:"IBM Plex Sans","Segoe UI",sans-serif;
      }
      .shell{
        min-height:100vh;
        display:flex;
        align-items:center;
        justify-content:center;
        padding:32px 18px;
      }
      .card{
        width:min(100%, 940px);
        background:rgba(255,250,242,.92);
        border:1px solid var(--error-line);
        border-radius:28px;
        box-shadow:0 30px 120px rgba(20,32,43,.12);
        overflow:hidden;
      }
      .hero{
        padding:32px 28px 20px;
        border-bottom:1px solid var(--error-line);
      }
      .eyebrow{
        display:inline-flex;
        align-items:center;
        gap:10px;
        padding:8px 12px;
        border-radius:999px;
        background:var(--error-accent-soft);
        color:var(--error-accent);
        font-size:12px;
        font-weight:700;
        letter-spacing:.12em;
        text-transform:uppercase;
      }
      .headline{
        margin:18px 0 10px;
        font-family:"IBM Plex Serif","Georgia",serif;
        font-size:clamp(2.4rem, 6vw, 5.6rem);
        line-height:.95;
        letter-spacing:-.05em;
      }
      .summary{
        max-width:42rem;
        margin:0;
        color:var(--error-muted);
        font-size:1.05rem;
        line-height:1.7;
      }
      .grid{
        display:grid;
        grid-template-columns:1.2fr .8fr;
      }
      .panel{
        padding:24px 28px 30px;
      }
      .panel + .panel{
        border-left:1px solid var(--error-line);
      }
      .section-title{
        margin:0 0 14px;
        font-size:.78rem;
        letter-spacing:.16em;
        text-transform:uppercase;
        color:var(--error-muted);
      }
      .request-list{
        display:grid;
        gap:12px;
      }
      .request-item{
        display:flex;
        justify-content:space-between;
        gap:18px;
        padding:12px 0;
        border-bottom:1px solid var(--error-line);
      }
      .request-item:last-child{border-bottom:none}
      .request-key{
        color:var(--error-muted);
        font-size:.92rem;
      }
      .request-value{
        font-weight:600;
        text-align:right;
        word-break:break-word;
      }
      .code{
        display:inline-flex;
        align-items:flex-end;
        gap:14px;
        margin-bottom:18px;
      }
      .code-number{
        font-size:4.4rem;
        line-height:.85;
        font-weight:800;
        letter-spacing:-.08em;
      }
      .code-text{
        padding-bottom:8px;
        color:var(--error-muted);
        font-size:1rem;
      }
      .debug{
        margin-top:18px;
        padding:16px;
        border-radius:18px;
        background:#f6efe4;
        border:1px solid rgba(20,32,43,.09);
      }
      .debug dl{
        margin:0;
        display:grid;
        gap:12px;
      }
      .debug dt{
        margin:0 0 4px;
        color:var(--error-muted);
        font-size:.8rem;
        text-transform:uppercase;
        letter-spacing:.12em;
      }
      .debug dd{
        margin:0;
        font-size:.95rem;
        line-height:1.6;
        white-space:pre-wrap;
        word-break:break-word;
      }
      @media (max-width: 800px){
        .grid{grid-template-columns:1fr}
        .panel + .panel{border-left:none;border-top:1px solid var(--error-line)}
        .headline{font-size:clamp(2.2rem, 14vw, 4rem)}
        .request-item{flex-direction:column;align-items:flex-start}
        .request-value{text-align:left}
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <article class="card">
        <section class="hero">
          <div class="eyebrow">{{ eyebrow|default('Semitexa SSR') }}</div>
          <h1 class="headline">{{ headline|default('Something went wrong.') }}</h1>
          <p class="summary">{{ summary|default('The framework reached the error renderer and returned the default SSR fallback page.') }}</p>
        </section>
        <section class="grid">
          <div class="panel">
            <p class="section-title">HTTP Status</p>
            <div class="code">
              <div class="code-number">{{ statusCode|default(500) }}</div>
              <div class="code-text">{{ reasonPhrase|default('Error') }}</div>
            </div>
            {% if debugDetails is not empty %}
              <div class="debug">
                <p class="section-title">Debug Details</p>
                <dl>
                  {% for label, value in debugDetails %}
                    <dt>{{ label }}</dt>
                    <dd>{{ value }}</dd>
                  {% endfor %}
                </dl>
              </div>
            {% endif %}
          </div>
          <div class="panel">
            <p class="section-title">Request</p>
            <div class="request-list">
              {% for label, value in requestDetails|default({}) %}
                <div class="request-item">
                  <div class="request-key">{{ label }}</div>
                  <div class="request-value">{{ value }}</div>
                </div>
              {% endfor %}
            </div>
          </div>
        </section>
      </article>
    </div>
    {{ asset_body() }}
  </body>
</html>
